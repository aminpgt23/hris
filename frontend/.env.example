# ===========================================
# HRIS Payroll Enterprise - Frontend Environment
# ===========================================
# Copy this file to .env and fill in your actual values

# -------------------------------------------
# React App Configuration
# -------------------------------------------
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_VERSION=v1

# -------------------------------------------
# App Branding
# -------------------------------------------
REACT_APP_COMPANY_NAME=Your Company Name
REACT_APP_APP_NAME=HRIS Payroll Enterprise

# -------------------------------------------
# Authentication
# -------------------------------------------
REACT_APP_JWT_TOKEN_NAME=auth_token
REACT_APP_SESSION_TIMEOUT=3600

# -------------------------------------------
# Feature Flags (must match backend)
# -------------------------------------------
REACT_APP_ENABLE_BIOMETRIC=true
REACT_APP_ENABLE_GPS=true
REACT_APP_ENABLE_LEAVE_REQUEST=true
REACT_APP_ENABLE_PAYROLL_VIEW=true

# -------------------------------------------
# File Upload
# -------------------------------------------
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# -------------------------------------------
# Maps / GPS Configuration
# -------------------------------------------
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
REACT_APP_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# -------------------------------------------
# Notification Configuration
# -------------------------------------------
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123

# -------------------------------------------
# Analytics & Monitoring
# -------------------------------------------
REACT_APP_SENTRY_DSN=your_sentry_dsn
REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# -------------------------------------------
# Environment
# -------------------------------------------
REACT_APP_ENV=development
REACT_APP_DEBUG=true
