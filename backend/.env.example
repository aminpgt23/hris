# ===========================================
# HRIS Payroll Enterprise - Backend Environment
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git (it's in .gitignore)

# -------------------------------------------
# Server Configuration
# -------------------------------------------
NODE_ENV=development
PORT=5000
API_VERSION=v1

# -------------------------------------------
# Database Configuration (MySQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hris_payroll_db
DB_USER=root
DB_PASSWORD=your_secure_password_here

# For production with primary + backup
# DB_HOST_PRIMARY=primary-db.example.com
# DB_HOST_BACKUP=backup-db.example.com

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# -------------------------------------------
# Encryption & Security
# -------------------------------------------
ENCRYPTION_KEY=your_32_character_encryption_key_here_for_sensitive_data
BCRYPT_ROUNDS=10

# -------------------------------------------
# Session Configuration
# -------------------------------------------
SESSION_SECRET=your_session_secret_key_here

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
CORS_ORIGIN=http://localhost:3000
# For production: CORS_ORIGIN=https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# Email Configuration (SMTP)
# -------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@yourcompany.com

# Alternative: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# -------------------------------------------
# SMS/WhatsApp Gateway
# -------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Or use local SMS gateway
# SMS_GATEWAY_URL=https://your-sms-gateway.com/api
# SMS_GATEWAY_API_KEY=your_sms_gateway_key

# -------------------------------------------
# File Upload Configuration
# -------------------------------------------
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# AWS S3 (optional for production)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=your-bucket-name

# -------------------------------------------
# Biometric Device Integration
# -------------------------------------------
BIOMETRIC_DEVICE_IP=192.168.1.100
BIOMETRIC_DEVICE_PORT=4370
BIOMETRIC_DEVICE_COMM_KEY=0

# -------------------------------------------
# GPS/Geo-location API
# -------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# -------------------------------------------
# Payment/Bank Gateway
# -------------------------------------------
BANK_API_URL=https://api.bank-example.com
BANK_API_KEY=your_bank_api_key
BANK_MERCHANT_ID=your_merchant_id

# -------------------------------------------
# BPJS & Tax Integration (E-Filing)
# -------------------------------------------
BPJS_API_URL=https://api.bpjs-kesehatan.go.id
BPJS_USERNAME=your_bpjs_username
BPJS_PASSWORD=your_bpjs_password
BPJS_COMPANY_CODE=your_company_code

# PPh21 E-Filing
# DJP_API_URL=https://djponline.pajak.go.id/api
# DJP_API_KEY=your_djp_api_key

# -------------------------------------------
# Notification Services
# -------------------------------------------
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKey\n-----END PRIVATE KEY-----"

# Push Notification
# ONESIGNAL_APP_ID=your_onesignal_app_id
# ONESIGNAL_API_KEY=your_onesignal_api_key

# -------------------------------------------
# Redis (for caching & sessions)
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------
# Logging & Monitoring
# -------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Backup Configuration
# -------------------------------------------
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *

# -------------------------------------------
# Multi-Company Configuration
# -------------------------------------------
DEFAULT_COMPANY_ID=1
SUPPORT_MULTI_COMPANY=true

# -------------------------------------------
# Feature Flags
# -------------------------------------------
ENABLE_BIOMETRIC=true
ENABLE_GPS=true
ENABLE_AUTO_PAYROLL=true
ENABLE_NOTIFICATION=true
